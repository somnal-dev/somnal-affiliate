# API Keys (실제 키는 .env 파일에 저장)
# 쿠팡 파트너스
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# 아마존 어소시에이트
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_ASSOCIATE_TAG=

# 알리익스프레스
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# 셔기
SHEIN_AFFILIATE_ID=
SHEIN_SECRET=

# 인스타그램 Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# GLM-5 API
GLM5_API_KEY=your_glm5_api_key_here
GLM5_BASE_URL=https://api.z.ai/api/coding/paas/v4

# 시스템 설정
PORT=3004
DM_DAILY_LIMIT=50
HUNT_DAILY_LIMIT=20
MOCK_MODE=true
